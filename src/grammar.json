{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "draft",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "section"
          },
          {
            "type": "SYMBOL",
            "name": "narrative"
          },
          {
            "type": "SYMBOL",
            "name": "dialog"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "tag"
              },
              {
                "type": "SYMBOL",
                "name": "_eol"
              }
            ]
          }
        ]
      }
    },
    "section": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "ALIAS",
            "content": {
              "type": "SYMBOL",
              "name": "name_section"
            },
            "named": true,
            "value": "name"
          },
          {
            "type": "SYMBOL",
            "name": "_eol"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "narrative"
                },
                {
                  "type": "SYMBOL",
                  "name": "comment"
                },
                {
                  "type": "SYMBOL",
                  "name": "dialog"
                }
              ]
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "stop_section"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "name_section": {
      "type": "PATTERN",
      "value": ">[^\\n]+"
    },
    "stop_section": {
      "type": "STRING",
      "value": "<\n"
    },
    "comment": {
      "type": "PATTERN",
      "value": "[ \\t]+[^>\\n]*\\n"
    },
    "tag": {
      "type": "PATTERN",
      "value": "[#]+[^\\n]+"
    },
    "narrative": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[^\\t>—\\n]"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^\\t>\\n]+"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        }
      ]
    },
    "dialog": {
      "type": "CHOICE",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_end_dialog"
          },
          "named": true,
          "value": "speech"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "REPEAT1",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "ALIAS",
                    "content": {
                      "type": "SYMBOL",
                      "name": "_open_dialog"
                    },
                    "named": true,
                    "value": "speech"
                  },
                  {
                    "type": "ALIAS",
                    "content": {
                      "type": "SYMBOL",
                      "name": "_open_narrative"
                    },
                    "named": true,
                    "value": "narrative"
                  }
                ]
              }
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "_end_dialog"
              },
              "named": true,
              "value": "speech"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "REPEAT1",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "ALIAS",
                    "content": {
                      "type": "SYMBOL",
                      "name": "_open_dialog"
                    },
                    "named": true,
                    "value": "speech"
                  },
                  {
                    "type": "ALIAS",
                    "content": {
                      "type": "SYMBOL",
                      "name": "_open_narrative"
                    },
                    "named": true,
                    "value": "narrative"
                  }
                ]
              }
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "_open_dialog"
              },
              "named": true,
              "value": "speech"
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "_end_narrative"
              },
              "named": true,
              "value": "narrative"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "_open_dialog"
              },
              "named": true,
              "value": "speech"
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "_end_narrative"
              },
              "named": true,
              "value": "narrative"
            }
          ]
        }
      ]
    },
    "_open_dialog": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "—"
        },
        {
          "type": "PATTERN",
          "value": "[^—\\n]+"
        },
        {
          "type": "STRING",
          "value": "—"
        }
      ]
    },
    "_end_dialog": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "—"
        },
        {
          "type": "PATTERN",
          "value": "[^—\\n]+"
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        }
      ]
    },
    "_open_narrative": {
      "type": "PATTERN",
      "value": "[^\\t>—\\n]+"
    },
    "_end_narrative": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[^\\t>—\\n]+"
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        }
      ]
    },
    "_eol": {
      "type": "STRING",
      "value": "\n"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}